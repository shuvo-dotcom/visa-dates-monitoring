{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "outDir": ".scripts-out",
    "target": "ES2020"
  },
  "include": ["scripts/**/*.ts", "lib/types.ts"]
}
